# ============================================================
# vps-bootstrap — sensitive variables
# Copy this file: cp vars/secret.yml.example vars/secret.yml
# Fill in your values and NEVER commit vars/secret.yml
#
# Optional — encrypt with Ansible Vault:
#   ansible-vault encrypt vars/secret.yml
# ============================================================

# --- Server ---
secret_vps_ip: "000.000.000.000"
secret_ssh_port: 22XX

# --- Deploy user ---
secret_deploy_user: "deploy"

# --- Domain and TLS ---
secret_airflow_domain: "airflow.yourdomain.com"
secret_caddy_tls_email: "you@example.com"

# --- Airflow ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
secret_airflow_secret_key: "generate-a-strong-random-value"
secret_airflow_admin_username: "admin"
secret_airflow_admin_password: "your-strong-admin-password"

# --- PostgreSQL ---
secret_postgres_password: "your-strong-postgres-password"