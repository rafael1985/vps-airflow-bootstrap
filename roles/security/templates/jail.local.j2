# Generated by vps-bootstrap — do not edit manually
# roles/security/templates/jail.local.j2

[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
backend  = systemd

[sshd]
enabled  = true
port     = {{ ssh_port }}
filter   = sshd
logpath  = /var/log/secure
maxretry = {{ fail2ban_maxretry }}

[caddy-4xx]
enabled  = true
port     = http,https
filter   = caddy-4xx
logpath  = /var/log/caddy/airflow.log
maxretry = 20
findtime = 60
bantime  = 600
