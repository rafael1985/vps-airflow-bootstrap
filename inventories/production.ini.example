# ============================================================
# First run — fresh VPS, SSH on port 22 as root
# After provisioning, update ansible_port and ansible_user
# ============================================================

[vps]
meuservidor ansible_host=000.000.000.000 ansible_port=22 ansible_user=root

[vps:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_private_key_file=~/.ssh/id_ed25519
